rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // User uploads - only the owner can access their files
    match /uploads/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Shared zips - publicly readable for anyone with the link
    match /shared_zips/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
